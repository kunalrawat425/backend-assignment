# ===== Core =====
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ===== Database (Supabase: use pgbouncer URL on port 6543 for app, 5432 for migrations) =====
DATABASE_URL=postgresql://buffalo:buffalo@localhost:5432/buffalo?schema=public
DIRECT_URL=postgresql://buffalo:buffalo@localhost:5432/buffalo?schema=public

# ===== API Auth =====
API_KEY=replace-with-random-hex-32
ADMIN_API_KEY=replace-with-random-hex-32-stronger

# ===== Stripe =====
STRIPE_ENABLED=true
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===== HubSpot =====
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=pat-na1-xxx
HUBSPOT_WEBHOOK_SECRET=xxx

# ===== Google Calendar =====
GCAL_ENABLED=false
GOOGLE_CLIENT_EMAIL=svc-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary

# ===== Rate-limit / retry / backoff =====
RATE_LIMIT_PER_SEC=10
MAX_RETRIES=5
BACKOFF_BASE_MS=1000
FULL_BACKFILL_MIN_INTERVAL_MIN=60

# ===== Notifier (Resend free tier 3k/mo) =====
RESEND_API_KEY=re_xxx
NOTIFY_TO=kunalrawat425@gmail.com
NOTIFY_FROM=buffalo@resend.dev
NOTIFY_ON=failure,recovery,daily
NOTIFY_DAILY_AT_UTC=09:00

# ===== Outbox =====
OUTBOX_BATCH_SIZE=50
