{
  "name": "buffalo",
  "version": "0.1.0",
  "private": true,
  "description": "Unified ingestion pipeline (HubSpot, Stripe, Google Calendar) + revenue metrics service",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=tests/integration",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx seeders/seed.ts",
    "gen:env-example": "tsx scripts/gen-env-example.ts",
    "check:single-revenue": "bash scripts/check-single-revenue-impl.sh",
    "job:fetch": "tsx src/jobs/producer.job.ts",
    "job:process": "tsx src/jobs/processor.job.ts",
    "job:daily-summary": "tsx src/jobs/daily-summary.job.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.0.0",
    "@prisma/client": "^5.20.0",
    "amqplib": "^0.10.4",
    "axios": "^1.7.0",
    "bottleneck": "^2.19.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.7.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
