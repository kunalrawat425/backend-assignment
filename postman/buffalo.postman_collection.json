              "body": "{ \"granularity\": \"day\", \"totalCollectedCents\": \"209800\", \"totalTxnCount\": 4, \"buckets\": [{ \"bucketStart\": \"2026-06-15T00:00:00.000Z\", \"collectedCents\": \"209800\", \"txnCount\": 4 }, { \"bucketStart\": \"2026-06-16T00:00:00.000Z\", \"collectedCents\": \"0\", \"txnCount\": 0 }] }"
            }
