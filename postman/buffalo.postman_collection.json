    {
      "name": "Metrics — Revenue",
      "item": [
        {
          "name": "GET /metrics/revenue — summary (all sources)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/metrics/revenue?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z",
              "host": ["{{BASE_URL}}"],
              "path": ["metrics", "revenue"],
              "query": [
                { "key": "from", "value": "2026-01-01T00:00:00Z" },
                { "key": "to", "value": "2026-12-31T23:59:59Z" }
              ]
            },
            "header": [{ "key": "X-Api-Key", "value": "{{API_KEY}}" }]
          },
          "response": [
            {
              "name": "200 summary",
              "status": "OK",
              "code": 200,
              "body": "{ \"totalCollectedCents\": \"209800\", \"txnCount\": 4, \"from\": \"2026-01-01T00:00:00.000Z\", \"to\": \"2026-12-31T23:59:59.000Z\", \"source\": null }"
