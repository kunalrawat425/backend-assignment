        {
          "name": "GET /metrics/revenue — 400 range > 366 days",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/metrics/revenue?from=2024-01-01T00:00:00Z&to=2026-12-31T23:59:59Z",
              "host": ["{{BASE_URL}}"],
              "path": ["metrics", "revenue"],
              "query": [
                { "key": "from", "value": "2024-01-01T00:00:00Z" },
                { "key": "to", "value": "2026-12-31T23:59:59Z" }
